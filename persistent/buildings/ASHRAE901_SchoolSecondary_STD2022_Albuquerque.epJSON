    "EnergyManagementSystem:OutputVariable": {
        "Wired_LTG": {
            "ems_variable_name": "Wired_LTG",
            "type_of_data_in_variable": "Summed",
            "units": "J",
            "update_frequency": "ZoneTimestep"
        }
    },
    "EnergyManagementSystem:Program": {
        "OA_BASED_OPTIMUM_START_EMS_Program": {
            "lines": [
                {
                    "program_line": "IF DaylightSavings==0 && DayOfWeek>1 && DayOfWeek<7 && Hour==6 && OAT<23.9 && OAT>1.7"
                },
                {
                    "program_line": "SET CLGSETP_SCH_Actuator = 29.44"
                },
                {
                    "program_line": "SET HTGSETP_SCH_Actuator = 15.6"
                },
                {
                    "program_line": "SET CLGSETP_SCH_w_SB_Actuator = 29.44"
                },
                {
                    "program_line": "SET HTGSETP_SCH_w_SB_Actuator = 15.6"
                },
                {
                    "program_line": "ELSEIF DaylightSavings==1 && DayOfWeek>1 && DayOfWeek<7 && Hour==5 && OAT<23.9 && OAT>1.7"
                },
                {
                    "program_line": "SET CLGSETP_SCH_Actuator = 29.44"
                },
                {
                    "program_line": "SET HTGSETP_SCH_Actuator = 15.6"
                },
                {
                    "program_line": "SET CLGSETP_SCH_w_SB_Actuator = 29.44"
                },
                {
                    "program_line": "SET HTGSETP_SCH_w_SB_Actuator = 15.6"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET CLGSETP_SCH_Actuator = NULL"
                },
                {
                    "program_line": "SET HTGSETP_SCH_Actuator = NULL"
                },
                {
                    "program_line": "SET CLGSETP_SCH_w_SB_Actuator = NULL"
                },
                {
                    "program_line": "SET HTGSETP_SCH_w_SB_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SET_AUDITORIUM_ZN_1_FLR_1_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET AUDITORIUM_ZN_1_FLR_1_LSr_IP=0.093*AUDITORIUM_ZN_1_FLR_1_LSr/AUDITORIUM_ZN_1_FLR_1_Area"
                },
                {
                    "program_line": "IF (AUDITORIUM_ZN_1_FLR_1_OSr <= 0) && (AUDITORIUM_ZN_1_FLR_1_LSr_IP >= 0.02)"
