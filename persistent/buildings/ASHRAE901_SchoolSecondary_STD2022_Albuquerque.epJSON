        "SetBoilerCurve": {
            "lines": [
                {
                    "program_line": "IF BoilerPLR >= PLRx"
                },
                {
                    "program_line": "IF BoilerType == 1"
                },
                {
                    "program_line": "SET BoilerCurve = 0.975 + 0.305*BoilerPLR - 0.527*(BoilerPLR^2) + 0.249*(BoilerPLR^3)"
                },
                {
                    "program_line": "ELSEIF BoilerType == 2"
                },
                {
                    "program_line": "SET BoilerCurve = 0.907 + 0.320*BoilerPLR - 0.420*(BoilerPLR^2) + 0.193*(BoilerPLR^3)"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET BoilerCurve = 0.492 + 1.41*BoilerPLR - 1.529*(BoilerPLR^2) + 0.628*(BoilerPLR^3)"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "IF BoilerPLR == 0"
                },
                {
                    "program_line": "SET BoilerCurve = NULL"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "IF BoilerPLR <0.05"
                },
                {
                    "program_line": "SET BoilerCurve = (0.05/(0.05 + SkinLossRate)) * (Ecx/EtRated)"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET BoilerCurve = (BoilerPLR/(BoilerPLR + SkinLossRate)) * (Ecx/EtRated)"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SetBoilerPar": {
            "lines": [
                {
                    "program_line": "SET CapRated =  696056.11"
                },
                {
                    "program_line": "SET EtRated =  0.945"
                },
                {
                    "program_line": "SET CapRated = (CapRated *3.412)/1000"
                },
                {
                    "program_line": "SET SkinLossRate = 0.02"
                },
                {
                    "program_line": "SET BoilerType = 1"
                },
                {
                    "program_line": "IF BoilerType  == 1"
                },
                {
                    "program_line": "IF CapRated >10000"
                },
                {
                    "program_line": "SET PLRx = 0.2"
                },
                {
                    "program_line": "ELSEIF CapRated >5000"
                },
                {
                    "program_line": "SET PLRx = 0.25"
                },
                {
                    "program_line": "ELSEIF CapRated >1000"
                },
                {
                    "program_line": "SET PLRx = 0.33"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET BoilerType = 2"
                },
                {
                    "program_line": "SET PLRx = 0.2"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET PLRx = 0.2"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "IF BoilerType == 1"
                },
                {
                    "program_line": "SET CurveX = 0.975 + 0.305 * PLRx - 0.527 * (PLRx^2) + 0.249 * (PLRx^3)"
                },
                {
                    "program_line": "ELSEIF BoilerType == 2"
                },
                {
                    "program_line": "SET CurveX = 0.907 + 0.320 * PLRx - 0.420 * (PLRx^2) + 0.193 * (PLRx^3)"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET CurveX = 0.492 + 1.41 * PLRx - 1.529 * (PLRx^2) + 0.628 * (PLRx^3)"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "SET LoadX = CapRated * PLRx"
                },
                {
                    "program_line": "SET Etx = CurveX * EtRated"
                },
                {
                    "program_line": "SET InputEx = LoadX/Etx"
                },
                {
                    "program_line": "SET SkinEx = CapRated * SkinLossRate"
                },
                {
                    "program_line": "SET Ecx = (LoadX + SkinEx)/InputEx"
                }
            ]
        },
        "Transformer_Load_Prog": {
            "lines": [
                {
                    "program_line": "SET Wired_LTG = Facility_Int_LTG*0.0194"
                }
            ]
        },
        "vav_other_MAX_OA_FRAC": {
            "lines": [
                {
                    "program_line": "IF vav_other_OA > vav_other_OA_VRP"
                },
                {
                    "program_line": "SET vav_other_MAX_OA_FRAC = NULL"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "IF vav_other_SUPPLY_FLOW > 0"
