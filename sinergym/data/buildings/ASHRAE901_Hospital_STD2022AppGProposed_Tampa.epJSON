    "EnergyManagementSystem:Program": {
        "BypassHXStatus_Prg": {
            "lines": [
                {
                    "program_line": "SET HLOAD = HotWaterDemand /  (143319.7906 * ((1/2.9755) + 1))"
                },
                {
                    "program_line": "SET HLOAD = @Min HLOAD 1"
                },
                {
                    "program_line": "SET HLOAD = CHWR - (HLOAD * 8.33)"
                },
                {
                    "program_line": "SET HLOAD = @Max HLOAD 6.7"
                },
                {
                    "program_line": "SET HRC_SPM_Reset = @Min HLOAD 14.44"
                }
            ]
        },
        "ChangTowerFlow": {
            "lines": [
                {
                    "program_line": "IF Chiller1_Status > 0 && Chiller2_Status == 0 && SensedCurveInput > 0.2"
                },
                {
                    "program_line": "IF (0.5 * SensedCurveInput) > 0.2"
                },
                {
                    "program_line": "SET AirInput = 0.5 * SensedCurveInput"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET AirInput = 0.2"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "SET TowerCurveOutput =  2* (AirInput^3)"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET TowerCurveOutput = SensedCurveValue"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "PlantPump_EMS_Program": {
            "lines": [
                {
                    "program_line": "IF ChillerPlantDemandLoad < 1023712.79"
                },
                {
                    "program_line": "SET Chiller2PumpStatus = 0"
                },
                {
                    "program_line": "SET Chiller2Status = 0"
                },
                {
                    "program_line": "SET Chiller2PumpFlow = 0"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Chiller2PumpStatus = 1"
                },
                {
                    "program_line": "SET Chiller2Status = 1"
                },
                {
                    "program_line": "SET Chiller2PumpFlow = Chiller2PumpDesignFlow"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SetBoilerCurve": {
            "lines": [
                {
                    "program_line": "IF BoilerPLR >= PLRx"
                },
                {
                    "program_line": "IF BoilerType == 1"
                },
                {
                    "program_line": "SET BoilerCurve = 0.975 + 0.305*BoilerPLR - 0.527*(BoilerPLR^2) + 0.249*(BoilerPLR^3)"
                },
                {
                    "program_line": "ELSEIF BoilerType == 2"
                },
                {
                    "program_line": "SET BoilerCurve = 0.907 + 0.320*BoilerPLR - 0.420*(BoilerPLR^2) + 0.193*(BoilerPLR^3)"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET BoilerCurve = 0.492 + 1.41*BoilerPLR - 1.529*(BoilerPLR^2) + 0.628*(BoilerPLR^3)"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "IF BoilerPLR == 0"
                },
                {
                    "program_line": "SET BoilerCurve = NULL"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "IF BoilerPLR <0.05"
                },
                {
                    "program_line": "SET BoilerCurve = (0.05/(0.05 + SkinLossRate)) * (Ecx/EtRated)"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET BoilerCurve = (BoilerPLR/(BoilerPLR + SkinLossRate)) * (Ecx/EtRated)"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SetBoilerPar": {
            "lines": [
                {
                    "program_line": "SET CapRated =  1742529.37"
                },
                {
                    "program_line": "SET EtRated =  0.9"
                },
                {
                    "program_line": "SET CapRated = (CapRated *3.412)/1000"
                },
                {
                    "program_line": "SET SkinLossRate = 0.02"
                },
                {
                    "program_line": "SET BoilerType = 1"
                },
                {
                    "program_line": "IF BoilerType  == 1"
                },
                {
                    "program_line": "IF CapRated >10000"
                },
                {
                    "program_line": "SET PLRx = 0.2"
                },
                {
                    "program_line": "ELSEIF CapRated >5000"
                },
                {
                    "program_line": "SET PLRx = 0.25"
                },
                {
                    "program_line": "ELSEIF CapRated >1000"
                },
                {
                    "program_line": "SET PLRx = 0.33"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET BoilerType = 2"
                },
                {
                    "program_line": "SET PLRx = 0.2"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET PLRx = 0.2"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "IF BoilerType == 1"
                },
                {
                    "program_line": "SET CurveX = 0.975 + 0.305 * PLRx - 0.527 * (PLRx^2) + 0.249 * (PLRx^3)"
                },
                {
                    "program_line": "ELSEIF BoilerType == 2"
                },
                {
                    "program_line": "SET CurveX = 0.907 + 0.320 * PLRx - 0.420 * (PLRx^2) + 0.193 * (PLRx^3)"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET CurveX = 0.492 + 1.41 * PLRx - 1.529 * (PLRx^2) + 0.628 * (PLRx^3)"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "SET LoadX = CapRated * PLRx"
                },
                {
                    "program_line": "SET Etx = CurveX * EtRated"
                },
                {
                    "program_line": "SET InputEx = LoadX/Etx"
                },
                {
                    "program_line": "SET SkinEx = CapRated * SkinLossRate"
                },
                {
                    "program_line": "SET Ecx = (LoadX + SkinEx)/InputEx"
                }
            ]
        },
        "Transformer_Load_Prog": {
            "lines": [
                {
                    "program_line": "SET Wired_LTG = Facility_Int_LTG*0.022"
                }
            ]
        },
        "vav_1_MAX_OA_FRAC": {
            "lines": [
                {
                    "program_line": "IF vav_1_OA > vav_1_OA_VRP"
                },
                {
                    "program_line": "SET vav_1_MAX_OA_FRAC = NULL"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "IF vav_1_SUPPLY_FLOW > 0"
                },
                {
                    "program_line": "SET vav_1_MAX_OA_FRAC =  4.3268 / vav_1_SUPPLY_FLOW"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET vav_1_MAX_OA_FRAC = NULL"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "vav_2_MAX_OA_FRAC": {
            "lines": [
                {
                    "program_line": "IF vav_2_OA > vav_2_OA_VRP"
                },
                {
                    "program_line": "SET vav_2_MAX_OA_FRAC = NULL"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "IF vav_2_SUPPLY_FLOW > 0"
                },
                {
                    "program_line": "SET vav_2_MAX_OA_FRAC =  4.4797 / vav_2_SUPPLY_FLOW"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET vav_2_MAX_OA_FRAC = NULL"
                },
                {
                    "program_line": "ENDIF"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        }
    },
